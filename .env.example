# REQUIRED — your Discord webhook (Channel > Edit Channel > Integrations > Webhooks)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxx/yyyy

# Protect the web UI with a password (Basic Auth). Strongly recommended in the cloud.
# Username can be anything; this is the password.
APP_PASSWORD=choose-something-strong

# Optional tuning (sensible defaults shown)
SUBREDDIT=Watchexchange
POLL_INTERVAL_SECONDS=180
WATCH_REQUIRE_TAGS=WTS,WTT
MAX_POST_AGE_MINUTES=720
USER_AGENT=watchexchange-tracker/1.0 (personal RSS notifier)

# Point this at a persistent volume in the cloud so your watch list survives redeploys
# DB_PATH=/data/tracker.db
